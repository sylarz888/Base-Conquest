# Network RPCs
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# WalletConnect project ID (get from https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Contract addresses (populated after deploy script runs)
# These are filled in automatically by script/Deploy.s.sol into deployments/base-sepolia.json
# Copy the relevant address here for the frontend to pick up.
NEXT_PUBLIC_GAME_ENGINE_ADDRESS=
NEXT_PUBLIC_TERRITORY_NFT_ADDRESS=
NEXT_PUBLIC_ARMY_TOKEN_ADDRESS=
NEXT_PUBLIC_TERRITORY_CARD_ADDRESS=
NEXT_PUBLIC_TREASURY_VAULT_ADDRESS=
