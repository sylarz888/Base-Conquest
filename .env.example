# ── Deployer ──────────────────────────────────────────────────────────────────
# Private key of the deployer EOA (never commit a real key)
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# ── RPC Endpoints ─────────────────────────────────────────────────────────────
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ── Block Explorers ───────────────────────────────────────────────────────────
BASESCAN_API_KEY=YOUR_BASESCAN_API_KEY

# ── Chainlink VRF (Base Sepolia) ──────────────────────────────────────────────
# Create a subscription at https://vrf.chain.link/base-sepolia
VRF_SUBSCRIPTION_ID=1234
# Key hash for 200 gwei gas lane on Base Sepolia
VRF_KEY_HASH=0x9e9e46732b32662b9adc6f3abdf6c5e926a666d174a4d6b8e39c4cca76a38897
# VRF Coordinator address on Base Sepolia
VRF_COORDINATOR=0x5C210eF41CD1a72de73bF76eC39637bB0d3d7BEE

# ── Chainlink VRF (Base Mainnet) ──────────────────────────────────────────────
# VRF_SUBSCRIPTION_ID=
# VRF_KEY_HASH=0x9e9e46732b32662b9adc6f3abdf6c5e926a666d174a4d6b8e39c4cca76a38897
# VRF_COORDINATOR=0xd5D517aBE5cF79B7e95eC98dB0f0277788aFF634

# ── Game Config ───────────────────────────────────────────────────────────────
# Number of territories on the map (default: 42)
TERRITORY_COUNT=42
# Season duration in seconds (default: 90 days)
SEASON_DURATION=7776000
# Max territories a single wallet may hold at Season start (default: 12)
MAX_TERRITORIES_PER_WALLET=12

# ── Multisig ──────────────────────────────────────────────────────────────────
# Gnosis Safe address that holds DEFAULT_ADMIN_ROLE on mainnet
ADMIN_MULTISIG=0x0000000000000000000000000000000000000000
